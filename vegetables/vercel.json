{
  "builds": [
    {
      "src": "api/generate.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],

  "routes": [

    {
      "src": "/api/(.*)",
      "dest": "api/generate.py"
    },

    {
      "src": "/(.*)",
      "dest": "/index.html"
    }

  ]
}
